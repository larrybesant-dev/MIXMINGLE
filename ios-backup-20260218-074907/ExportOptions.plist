<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- iOS Export Options for App Store / TestFlight distribution -->
<plist version="1.0">
<dict>
    <key>method</key>
    <string>app-store</string>

    <key>teamID</key>
    <string>YOUR_TEAM_ID</string>

    <key>signingStyle</key>
    <string>automatic</string>

    <key>uploadBitcode</key>
    <false/>

    <key>uploadSymbols</key>
    <true/>

    <key>compileBitcode</key>
    <false/>

    <key>provisioningProfiles</key>
    <dict>
        <key>com.mixmingle.app</key>
        <string>Mix Mingle Production</string>
        <key>com.mixmingle.app.staging</key>
        <string>Mix Mingle Staging</string>
        <key>com.mixmingle.app.dev</key>
        <string>Mix Mingle Development</string>
    </dict>

    <key>destination</key>
    <string>export</string>

    <key>stripSwiftSymbols</key>
    <true/>
</dict>
</plist>
