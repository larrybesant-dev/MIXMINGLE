rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // HELPER FUNCTIONS
    // ========================================

    // Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if user is owner of document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check if user's email is verified
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Check if data field exists and is string
    function hasValidString(field) {
      return field in request.resource.data &&
             request.resource.data[field] is string &&
             request.resource.data[field].size() > 0;
    }

    // Check if data field exists and is number
    function hasValidNumber(field) {
      return field in request.resource.data &&
             request.resource.data[field] is number;
    }

    // Check if user is blocked by another user
    function isBlocked(userId) {
      return exists(/databases/$(database)/documents/users/$(userId)/blocked/$(request.auth.uid));
    }

    // Check if user has blocked another user
    function hasBlocked(userId) {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)/blocked/$(userId));
    }

    // Rate limiting helper - check timestamp
    function notTooFrequent(lastActionField, minIntervalSeconds) {
      return !(lastActionField in resource.data) ||
             request.time > resource.data[lastActionField] + duration.value(minIntervalSeconds, 's');
    }

    // ========================================
    // USERS COLLECTION
    // ========================================

    match /users/{userId} {
      // Anyone authenticated can read profiles
      allow read: if isSignedIn();

      // Users can create their own profile
      allow create: if isOwner(userId);

      // Users can update their own profile (for FCM tokens, display name, etc)
      allow update: if isOwner(userId);

      // Users can delete their own profile
      allow delete: if isOwner(userId);

      // FCM TOKENS SUBCOLLECTION
      match /fcmTokens/{tokenId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // FOLLOWERS SUBCOLLECTION
      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow create: if isOwner(followerId);
        allow delete: if isOwner(followerId);
      }

      // FOLLOWING SUBCOLLECTION
      match /following/{followingId} {
        allow read: if isSignedIn();
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // BLOCKED SUBCOLLECTION
      match /blocked/{blockedUserId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && blockedUserId != userId;
        allow delete: if isOwner(userId);
      }

      // EVENT RSVPS SUBCOLLECTION
      match /event_rsvps/{eventId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // ========================================
    // EVENTS COLLECTION
    // ========================================

    match /events/{eventId} {
      // Anyone authenticated can read events
      allow read: if isSignedIn();

      // Verified users can create events
      allow create: if isSignedIn() &&
                       hasValidString('title') &&
                       hasValidString('description') &&
                       request.resource.data.title.size() >= 3 &&
                       request.resource.data.title.size() <= 100 &&
                       request.resource.data.description.size() <= 2000;

      // Only host can update/delete event
      allow update, delete: if isOwner(resource.data.hostId);

      // EVENT ATTENDEES SUBCOLLECTION
      match /attendees/{attendeeId} {
        allow read: if isSignedIn();
        allow create: if isOwner(attendeeId);
        allow update, delete: if isOwner(attendeeId);
      }
    }

    // ========================================
    // ROOMS COLLECTION (Chat + Presence Schema)
    // ========================================

    match /rooms/{roomId} {
      // ✅ All authenticated users can READ rooms (discovery/joining)
      allow read: if isSignedIn();

      // ✅ Authenticated users can CREATE rooms with required metadata
      allow create: if isSignedIn() &&
                       hasValidString('name') &&
                       request.resource.data.name.size() >= 1 &&
                       request.resource.data.name.size() <= 200 &&
                       'type' in request.resource.data &&
                       request.resource.data.type in ['public', 'private', 'direct'] &&
                       'createdAt' in request.resource.data &&
                       'settings' in request.resource.data &&
                       request.resource.data.settings is map;

      // ✅ Only room creator can UPDATE metadata
      allow update: if isSignedIn() &&
                       request.auth.uid == resource.data.createdBy &&
                       // Prevent changing createdAt or createdBy
                       request.resource.data.createdAt == resource.data.createdAt &&
                       request.resource.data.createdBy == resource.data.createdBy;

      // ✅ Only room creator can DELETE
      allow delete: if isSignedIn() &&
                       request.auth.uid == resource.data.createdBy;

      // ========================================
      // MEMBERS SUBCOLLECTION - Presence Model
      // ========================================
      match /members/{userId} {
        // ✅ All authenticated users in ANY room can READ member/presence list
        allow read: if isSignedIn();

        // ✅ Users can WRITE only their own presence doc
        allow create, update: if isSignedIn() &&
                                 request.auth.uid == userId &&
                                 // Validate required fields
                                 'userId' in request.resource.data &&
                                 request.resource.data.userId == userId &&
                                 'online' in request.resource.data &&
                                 request.resource.data.online is bool &&
                                 'platform' in request.resource.data &&
                                 request.resource.data.platform in ['web', 'android', 'ios', 'unknown'];

        // ✅ Users can DELETE only their own presence doc (leave room)
        allow delete: if isSignedIn() &&
                         request.auth.uid == userId;
      }

      // ========================================
      // MESSAGES SUBCOLLECTION - Chat Model
      // ========================================
      match /messages/{messageId} {
        // ✅ All authenticated users can READ messages
        allow read: if isSignedIn();

        // ✅ Only authenticated users can CREATE messages
        allow create: if isSignedIn() &&
                         // Sender must be current user
                         request.resource.data.senderId == request.auth.uid &&
                         // Message text exists and has content
                         hasValidString('text') &&
                         request.resource.data.text.size() <= 5000 &&
                         // Sender name provided
                         hasValidString('senderName') &&
                         // Message type must be valid
                         'type' in request.resource.data &&
                         request.resource.data.type in ['text', 'system', 'image', 'join', 'leave'] &&
                         // Deleted flag defaults to false
                         request.resource.data.deleted == false &&
                         // createdAt must be serverTimestamp (CRITICAL)
                         request.resource.data.createdAt == request.time;

        // ✅ Only message sender can UPDATE (soft delete via flag)
        allow update: if isSignedIn() &&
                         request.auth.uid == resource.data.senderId &&
                         // Can only toggle deleted flag
                         request.resource.data.deleted != resource.data.deleted &&
                         // All other fields immutable
                         request.resource.data.text == resource.data.text &&
                         request.resource.data.senderId == resource.data.senderId &&
                         request.resource.data.createdAt == resource.data.createdAt &&
                         request.resource.data.type == resource.data.type;

        // ✅ Only message sender can DELETE
        allow delete: if isSignedIn() &&
                         request.auth.uid == resource.data.senderId;
      }

      // ROOM PARTICIPANTS SUBCOLLECTION (legacy - kept for backward compatibility)
      match /participants/{participantId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == participantId;
      }

      // ROOM EVENTS SUBCOLLECTION (join/leave logs)
      match /events/{eventId} {
        allow read, create: if isSignedIn();
      }
    }

    // ========================================
    // FLAT ROOM MESSAGES (legacy support)
    // ========================================

    match /room_messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.senderId);
    }

    // ========================================
    // CHAT ROOMS COLLECTION
    // ========================================

    match /chatRooms/{roomId} {
      // Only participants can read chat
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;

      // Users can create chats if not blocked
      allow create: if isSignedIn() &&
                       'participants' in request.resource.data &&
                       request.auth.uid in request.resource.data.participants;

      // Participants can update chat
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;

      // CHAT MESSAGES SUBCOLLECTION
      match /messages/{messageId} {
        allow read: if isSignedIn() &&
                       request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants;
        allow create: if isSignedIn() &&
                         request.resource.data.senderId == request.auth.uid &&
                         request.resource.data.text.size() <= 5000;
        allow delete: if isOwner(resource.data.senderId);
      }
    }

    // ========================================
    // TOP-LEVEL MESSAGES COLLECTION
    // ========================================

    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                       request.auth.uid == request.resource.data.senderId;
      allow update: if isSignedIn() &&
        (request.auth.uid == resource.data.senderId);
      allow delete: if isSignedIn() && request.auth.uid == resource.data.senderId;
    }

    // ========================================
    // DIRECT MESSAGES COLLECTION
    // ========================================

    match /direct_messages/{messageId} {
      allow read: if isSignedIn() &&
        (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if isSignedIn() &&
                       request.auth.uid == resource.data.senderId &&
                       request.resource.data.text.size() <= 5000;
      allow update: if isSignedIn() &&
        (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow delete: if isOwner(resource.data.senderId);
    }

    // ========================================
    // NOTIFICATIONS COLLECTION
    // ========================================

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ========================================
    // TIPS COLLECTION
    // ========================================

    match /tips/{tipId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ========================================
    // MEDIA COLLECTION (images, videos, files)
    // ========================================

    match /media/{mediaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                       hasValidString('type') &&
                       request.resource.data.type in ['image', 'video', 'file', 'audio'] &&
                       'uploadedBy' in request.resource.data &&
                       request.resource.data.uploadedBy == request.auth.uid &&
                       'url' in request.resource.data &&
                       'createdAt' in request.resource.data;
      allow update: if isSignedIn() && request.auth.uid == resource.data.uploadedBy;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.uploadedBy;
    }

    // ========================================
    // SPEED DATING SESSIONS
    // ========================================

    match /speedDatingSessions/{sessionId} {
      allow read: if isSignedIn() &&
        (request.auth.uid == resource.data.userId1 || request.auth.uid == resource.data.userId2);
      allow create: if isOwner(resource.data.userId1);
      allow update: if isSignedIn() &&
        (request.auth.uid == resource.data.userId1 || request.auth.uid == resource.data.userId2);
    }

    // ========================================
    // SPEED DATING MATCHES
    // ========================================

    match /speedDatingMatches/{matchId} {
      allow read: if isSignedIn() &&
        (request.auth.uid == resource.data.userId1 || request.auth.uid == resource.data.userId2);
      allow create: if isSignedIn();
      allow update: if isSignedIn() &&
        (request.auth.uid == resource.data.userId1 || request.auth.uid == resource.data.userId2);
    }

    // ========================================
    // REPORTS COLLECTION
    // ========================================

    match /reports/{reportId} {
      allow read: if false; // Server-side only
      allow create: if isSignedIn() &&
                       hasValidString('reporterId') &&
                       hasValidString('reportedId') &&
                       hasValidString('reason') &&
                       request.resource.data.reporterId == request.auth.uid &&
                       request.resource.data.reporterId != request.resource.data.reportedId &&
                       request.resource.data.reason.size() <= 1000;
      allow update, delete: if false;
    }

    // ========================================
    // CONFIG COLLECTION (read-only)
    // ========================================

    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ========================================
    // TAGS COLLECTION
    // ========================================

    match /tags/{tagId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false; // Server-side only
    }

    // ========================================
    // PRESENCE & HEARTBEAT (Real-time status)
    // ========================================

    match /presence/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /heartbeat/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // ========================================
    // AGORA TOKENS COLLECTION (token generation)
    // ========================================

    match /agora_tokens/{tokenId} {
      // Only the requesting user can read their own token
      allow read: if isSignedIn() &&
                     'userId' in resource.data &&
                     request.auth.uid == resource.data.userId;

      // Users can request tokens for themselves
      allow create: if isSignedIn() &&
                       'userId' in request.resource.data &&
                       request.resource.data.userId == request.auth.uid &&
                       'roomId' in request.resource.data &&
                       'token' in request.resource.data &&
                       'expiresAt' in request.resource.data;

      // Users can update their own tokens (refresh)
      allow update: if isSignedIn() &&
                       request.auth.uid == resource.data.userId &&
                       request.resource.data.userId == resource.data.userId;

      // Users can delete their own token records
      allow delete: if isSignedIn() &&
                       request.auth.uid == resource.data.userId;
    }

    // ========================================
    // VIDEO STATE COLLECTION (room video state)
    // ========================================

    match /rooms/{roomId}/videoState/{stateId} {
      // All participants can read video state
      allow read: if isSignedIn();

      // Users can create/update their own video state
      allow create, update: if isSignedIn() &&
                               'userId' in request.resource.data &&
                               request.resource.data.userId == request.auth.uid &&
                               'videoEnabled' in request.resource.data &&
                               request.resource.data.videoEnabled is bool &&
                               'audioEnabled' in request.resource.data &&
                               request.resource.data.audioEnabled is bool;

      // Users can only delete their own video state
      allow delete: if isSignedIn() &&
                       request.auth.uid == resource.data.userId;
    }

    // ========================================
    // ADMIN COLLECTION (server-side only)
    // ========================================

    match /admin/{document=**} {
      allow read, write: if false;
    }

    // ========================================
    // DEFAULT: DENY ALL
    // ========================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
