{
"version": "2.0.0",
"tasks": [
{
"label": "Run Flutter app",
"type": "shell",
"command": "flutter run",
"args": ["-d", "chrome"],
"isBackground": false,
"problemMatcher": [],
"group": "build"
},
{
"label": "Build Flutter Web App",
"type": "shell",
"command": "flutter build web --release --web-renderer canvaskit --base-href \"/\"",
"isBackground": false,
"group": "build"
},
{
"label": "Build Flutter Web App (no renderer flag)",
"type": "shell",
"command": "flutter build web --release --base-href \"/\"",
"isBackground": false,
"group": "build"
},
{
"label": "Flutter Clean",
"type": "shell",
"command": "flutter",
"args": ["clean"],
"group": "build",
"problemMatcher": [],
"presentation": {
"reveal": "silent"
}
},
{
"label": "Patch Flutter Web Runtime",
"type": "shell",
"command": "powershell",
"args": ["-ExecutionPolicy", "Bypass", "-File", "tools/patch_flutter_web_runtime.ps1"],
"isBackground": false,
"group": "build"
},
{
"label": "Build Flutter Web App (patched)",
"type": "shell",
"command": "flutter build web --release --base-href \"/\"; powershell -ExecutionPolicy Bypass -File tools/patch_flutter_web_runtime.ps1",
"isBackground": false,
"group": "build"
}
]
}
