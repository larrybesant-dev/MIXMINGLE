{
  "dart.analysisExcludedFolders": [
    "backup",
    "backup/**",
    "backup_copilot_mega",
    "backup_copilot_mega/**",
    "build",
    "build/**",
    ".dart_tool",
    ".dart_tool/**",
    "functions/node_modules",
    "functions/node_modules/**",
    "functions/lib",
    "functions/lib/**"
  ],
  // ⚠️ CRITICAL: Disable hot reload on save - breaks Agora video sessions
  // Manual hot reload (Ctrl+Shift+P → Flutter: Hot Reload) is safer
  "dart.flutterHotReloadOnSave": false,
  "dart.runPubGetOnPubspecChanges": "always",
  "dart.showTypeAnnotations": true,
  "dart.previewFlutterUiGuides": true,
  "dart.previewFlutterUiGuidesCustomTracking": true,
  "dart.flutterOutline": true,
  "dart.useLsp": true,
  "dart.enableSdkFormatter": false,
  "dart.closingLabels": true,
  "dart.lineLength": 120,
  "dart.debugExternalPackageLibraries": false,
  "dart.debugSdkLibraries": false,
  // ⚠️ IMPORTANT: Disable format-on-save to avoid breaking async code mid-edit
  "editor.formatOnSave": false,
  // ℹ️ Auto-save disabled: Race conditions with hot reload can cause loss of edits
  // Save manually with Ctrl+S
  "files.autoSave": "off",
  "files.autoSaveDelay": 1000,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "editor.tabSize": 2,
  "editor.detectIndentation": true,
  "editor.insertSpaces": true,
  "editor.codeLens": true,
  "editor.minimap.enabled": true,
  "editor.minimap.maxColumn": 120,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.suggestSelection": "first",
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": true
  },
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },
  "files.associations": {
    "*.dart": "dart",
    "pubspec.yaml": "yaml",
    "analysis_options.yaml": "yaml",
    "firebase.json": "jsonc",
    "*.json": "jsonc"
  },
  "search.exclude": {
    "**/backup": true,
    "**/backup_*": true,
    "**/build": true,
    "**/.dart_tool": true,
    "**/node_modules": true,
    "**/.firebase": true,
    "**/*.g.dart": true,
    "**/*.freezed.dart": true
  },
  "files.watcherExclude": {
    "**/backup/**": true,
    "**/backup_*/**": true,
    "**/build/**": true,
    "**/.dart_tool/**": true,
    "**/node_modules/**": true,
    "**/.firebase/**": true
  },
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell"
    },
    "Command Prompt": {
      "path": [
        "${env:windir}\\System32\\cmd.exe"
      ],
      "icon": "terminal-cmd"
    },
    "Git Bash": {
      "path": "C:\\Program Files\\Git\\bin\\bash.exe",
      "icon": "terminal-bash"
    }
  },
  "emmet.includeLanguages": {
    "dart": "html"
  },
  "errorLens.enabledDiagnosticLevels": [
    "error",
    "warning",
    "info"
  ],
  "todo-tree.general.tags": [
    "TODO",
    "FIXME",
    "BUG",
    "HACK",
    "NOTE",
    "XXX"
  ],
  "todo-tree.highlights.defaultHighlight": {
    "icon": "alert",
    "type": "text",
    "foreground": "#ffffff",
    "opacity": 50
  },
  "todo-tree.highlights.customHighlight": {
    "TODO": {
      "icon": "check",
      "foreground": "#ffcc00"
    },
    "FIXME": {
      "icon": "flame",
      "foreground": "#ff6b6b"
    },
    "BUG": {
      "icon": "bug",
      "foreground": "#ff0000"
    },
    "NOTE": {
      "icon": "note",
      "foreground": "#4ec9b0"
    }
  },
  "github.copilot.enable": {
    "*": true,
    "yaml": true,
    "plaintext": false,
    "markdown": true,
    "dart": true
  },
  "markdownlint.config": {
    "MD033": {
      "disable": true
    },
    "MD025": {
      "disable": true
    },
    "MD001": {
      "disable": true
    },
    "MD003": {
      "disable": true
    }
  },
  "java.configuration.updateBuildConfiguration": "automatic",
  "flutterTools.displayGetxContextMenu": false,
  "flutterTools.displayMobxContextMenu": false,
  "flutterTools.displayRiverpodContextMenu": true,
  "flutterTools.displayModularContextMenu": false
}
