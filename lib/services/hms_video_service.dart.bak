import 'dart:developer';
import 'package:flutter/foundation.dart';
import 'package:hmssdk_flutter/hmssdk_flutter.dart';
import 'package:firebase_auth/firebase_auth.dart';
import 'package:cloud_firestore/cloud_firestore.dart';
import 'package:cloud_functions/cloud_functions.dart';
import 'hms_video_service_web.dart' if (dart.library.io) 'hms_video_service_stub.dart';

/// 100ms Video Service for Flutter Web & Mobile
/// Better web support than Agora
class HMSVideoService implements HMSUpdateListener, HMSActionResultListener {
  static final HMSVideoService _instance = HMSVideoService._internal();
  factory HMSVideoService() => _instance;
  HMSVideoService._internal() {
    if (kIsWeb) {
      _webService = HMSVideoServiceWeb();
    }
  }

  final FirebaseAuth _auth = FirebaseAuth.instance;
  final FirebaseFirestore _firestore = FirebaseFirestore.instance;

  HMSSDK? _hmsSDK;
  HMSVideoServiceWeb? _webService;
  bool _isInitialized = false;
  HMSRoom? _currentRoom;
  HMSPeer? _localPeer;
  final List<HMSPeer> _remotePeers = [];
  bool _isMicMuted = false;
  bool _isVideoMuted = false;

  // Getters
  bool get isInitialized => kIsWeb ? (_webService?.isInitialized ?? false) : _isInitialized;
  HMSRoom? get currentRoom => _currentRoom;
  HMSPeer? get localPeer => _localPeer;
  List<HMSPeer> get remotePeers => _remotePeers;
  bool get isMicMuted => kIsWeb ? (_webService?.isMicMuted ?? false) : _isMicMuted;
  bool get isVideoMuted => kIsWeb ? (_webService?.isVideoMuted ?? false) : _isVideoMuted;
  // Aliases for compatibility
  bool get isAudioMuted => isMicMuted;
  HMSSDK? get hmsSDK => _hmsSDK;

  /// Initialize HMS SDK
  Future<void> initialize() async {
    if (_isInitialized) return;

    // Use web implementation on web platform
    if (kIsWeb) {
      try {
        await _webService?.initialize();
        _isInitialized = true;
        return;
      } catch (e) {
        log('❌ Failed to initialize web video: $e');
        rethrow;
      }
    }

    // Mobile implementation below
    try {
      log('🎥 Initializing 100ms SDK...');

      // Only initialize on mobile platforms
      if (defaultTargetPlatform != TargetPlatform.android && defaultTargetPlatform != TargetPlatform.iOS) {
        log('⚠️ 100ms SDK only supports Android and iOS');
        _isInitialized = true;
        return;
      }

      _hmsSDK = HMSSDK();
      await _hmsSDK!.build();

      // Add update listener
      _hmsSDK!.addUpdateListener(listener: this);

      _isInitialized = true;
      log('✅ 100ms SDK initialized successfully');
    } catch (e) {
      log('❌ Failed to initialize 100ms SDK: $e');
      rethrow;
    }
  }

  /// Join a room
  Future<void> joinRoom({
    required String roomId,
    required String userId,
    required String userName,
    String? authToken,
    bool requestPermissions = true,
  }) async {
    // Use web implementation on web platform
    if (kIsWeb) {
      await _webService?.joinRoom(
        roomId: roomId,
        userId: userId,
        userName: userName,
        authToken: authToken,
        requestPermissions: requestPermissions,
      );
      return;
    }

    // Mobile implementation below
    if (!_isInitialized || _hmsSDK == null) {
      log('⚠️ HMS SDK not available on this platform - skipping video');
      return; // Gracefully skip on unsupported platforms
    }

    try {
      log('🎥 Joining room: $roomId as $userName');

      // In production, get auth token from your backend
      // For now, you need to implement token generation
      final token = authToken ?? await _getAuthToken(roomId, userId, userName);

      final config = HMSConfig(
        authToken: token,
        userName: userName,
        // Note: userId is deprecated in HMS SDK, it's auto-generated
      );

      await _hmsSDK!.join(config: config);
      log('✅ Successfully joined room');
    } catch (e) {
      log('❌ Failed to join room: $e');
      rethrow;
    }
  }

  /// Leave the current room
  Future<void> leaveRoom() async {
    if (kIsWeb) {
      await _webService?.leaveRoom();
      return;
    }

    if (_hmsSDK != null && _currentRoom != null) {
      try {
        log('🎥 Leaving room...');
        await _hmsSDK!.leave(hmsActionResultListener: this);
        _currentRoom = null;
        _localPeer = null;
        _remotePeers.clear();
        log('✅ Left room successfully');
      } catch (e) {
        log('❌ Error leaving room: $e');
      }
    }
  }

  /// Toggle microphone
  Future<void> toggleMic() async {
    if (kIsWeb) {
      await _webService?.toggleMic();
      return;
    }

    if (_hmsSDK != null && _localPeer != null) {
      _isMicMuted = !_isMicMuted;
      await _hmsSDK!.toggleMicMuteState();
      log('🎙️ Mic ${_isMicMuted ? "muted" : "unmuted"}');
    }
  }

  /// Toggle camera
  Future<void> toggleCamera() async {
    if (kIsWeb) {
      await _webService?.toggleCamera();
      return;
    }
    if (_hmsSDK != null && _localPeer != null) {
      _isVideoMuted = !_isVideoMuted;
      await _hmsSDK!.toggleCameraMuteState();
      log('📹 Camera ${_isVideoMuted ? "muted" : "unmuted"}');
    }
  }

  /// Switch camera (front/back)
  Future<void> switchCamera() async {
    if (_hmsSDK != null) {
      await _hmsSDK!.switchCamera(hmsActionResultListener: this);
    }
  }

  /// Get auth token from backend
  Future<String> _getAuthToken(
    String roomId,
    String userId,
    String userName,
  ) async {
    try {
      // Call Firebase Cloud Function to generate token
      final callable = FirebaseFunctions.instance.httpsCallable('generate100msToken');
      final result = await callable.call({
        'roomId': roomId,
        'role': 'viewer-realtime', // Default role
      });

      return result.data['token'] as String;
    } catch (e) {
      log('❌ Failed to get auth token: $e');
      rethrow;
    }
  }

  /// Dispose resources
  Future<void> dispose() async {
    await leaveRoom();
    if (_hmsSDK != null) {
      _hmsSDK!.removeUpdateListener(listener: this);
      _hmsSDK!.destroy();
      _hmsSDK = null;
    }
    _isInitialized = false;
  }

  // HMSUpdateListener implementation
  @override
  void onJoin({required HMSRoom room}) {
    _currentRoom = room;
    log('✅ Joined room: ${room.name}');
  }

  @override
  void onPeerUpdate({required HMSPeer peer, required HMSPeerUpdate update}) {
    log('👤 Peer update: ${peer.name} - ${update.name}');

    if (peer.isLocal) {
      _localPeer = peer;
    } else {
      switch (update) {
        case HMSPeerUpdate.peerJoined:
          _remotePeers.add(peer);
          break;
        case HMSPeerUpdate.peerLeft:
          _remotePeers.removeWhere((p) => p.peerId == peer.peerId);
          break;
        default:
          break;
      }
    }
  }

  @override
  void onPeerListUpdate({required List<HMSPeer> addedPeers, required List<HMSPeer> removedPeers}) {
    log('👥 Peer list update: +${addedPeers.length} -${removedPeers.length}');

    for (var peer in addedPeers) {
      if (!peer.isLocal && !_remotePeers.any((p) => p.peerId == peer.peerId)) {
        _remotePeers.add(peer);
      } else if (peer.isLocal) {
        _localPeer = peer;
      }
    }

    for (var peer in removedPeers) {
      _remotePeers.removeWhere((p) => p.peerId == peer.peerId);
    }
  }

  @override
  void onRoomUpdate({required HMSRoom room, required HMSRoomUpdate update}) {
    _currentRoom = room;
    log('🏠 Room update: ${update.name}');
  }

  @override
  void onTrackUpdate({
    required HMSTrack track,
    required HMSTrackUpdate trackUpdate,
    required HMSPeer peer,
  }) {
    log('🎬 Track update: ${track.kind} - ${trackUpdate.name}');
  }

  @override
  void onHMSError({required HMSException error}) {
    log('❌ HMS Error: ${error.message}');
  }

  @override
  void onMessage({required HMSMessage message}) {
    log('💬 Message: ${message.message}');
  }

  @override
  void onRoleChangeRequest({required HMSRoleChangeRequest roleChangeRequest}) {
    log('🔄 Role change request');
  }

  @override
  void onUpdateSpeakers({required List<HMSSpeaker> updateSpeakers}) {
    // Handle active speakers
  }

  @override
  void onReconnecting() {
    log('🔄 Reconnecting...');
  }

  @override
  void onReconnected() {
    log('✅ Reconnected');
  }

  @override
  void onChangeTrackStateRequest({required HMSTrackChangeRequest hmsTrackChangeRequest}) {
    // Handle track state change requests
  }

  @override
  void onRemovedFromRoom({required HMSPeerRemovedFromPeer hmsPeerRemovedFromPeer}) {
    log('❌ Removed from room');
  }

  @override
  void onAudioDeviceChanged({HMSAudioDevice? currentAudioDevice, List<HMSAudioDevice>? availableAudioDevice}) {
    // Handle audio device changes
  }

  @override
  void onSessionStoreAvailable({HMSSessionStore? hmsSessionStore}) {
    // Handle session store
  }

  // HMSActionResultListener implementation
  @override
  void onSuccess({required HMSActionResultListenerMethod methodType, Map<String, dynamic>? arguments}) {
    log('✅ Action success: ${methodType.name}');
  }

  @override
  void onException(
      {required HMSActionResultListenerMethod methodType,
      Map<String, dynamic>? arguments,
      required HMSException hmsException}) {
    log('❌ Action failed: ${methodType.name} - ${hmsException.message}');
  }
}
