rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------
    // Helper: Auth Required
    // -------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    // -------------------------------
    // Helper: User Owns Document
    // -------------------------------
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // -------------------------------
    // Helper: Admin (for official packs)
    // -------------------------------
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // -------------------------------
    // Helper: Creator Pro Tier
    // -------------------------------
    function isCreatorPro() {
      return isSignedIn() && request.auth.token.tier == "creatorPro";
    }

    // -------------------------------
    // Helper: Premium Tier
    // -------------------------------
    function isPremiumOrAbove() {
      return isSignedIn() &&
        (request.auth.token.tier == "premium" || request.auth.token.tier == "creatorPro");
    }

    // ...existing code...
    // All collection and subcollection rules as consolidated previously
    // ...existing code...
    // ========================================
    // DEFAULT: DENY ALL
    // ========================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
