rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================
    // HELPER FUNCTIONS
    // ========================================

    // Check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if user is owner of document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check if user's email is verified
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Check if user has admin custom claim
    function isAdmin() {
      return isSignedIn() && request.auth.token.get('admin', false) == true;
    }

    // Check if data field exists and is string
    function hasValidString(field) {
      return field in request.resource.data &&
             request.resource.data[field] is string &&
             request.resource.data[field].size() > 0;
    }

    // Check if data field exists and is number
    function hasValidNumber(field) {
      return field in request.resource.data &&
             request.resource.data[field] is number;
    }

    // Check if user is blocked by another user
    function isBlocked(userId) {
      return exists(/databases/$(database)/documents/users/$(userId)/blocked/$(request.auth.uid));
    }

    // Check if user has blocked another user
    function hasBlocked(userId) {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)/blocked/$(userId));
    }

    // Rate limiting helper - check timestamp
    function notTooFrequent(lastActionField, minIntervalSeconds) {
      return !(lastActionField in resource.data) ||
             request.time > resource.data[lastActionField] + duration.value(minIntervalSeconds, 's');
    }

    // Check if user is a participant of a chat room
    function isChatParticipant(roomId) {
      return isSignedIn() &&
             request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants;
    }

    // Check if user is host/moderator of a live room
    function isRoomHost(roomId) {
      return isSignedIn() &&
             request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId;
    }

    // Check if the current update only touches fields safe for any participant
    // (joining/leaving increments participantCount; setVideoChannelLive; heartbeat)
    function isRoomJoinUpdate() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['participantCount', 'updatedAt', 'videoChannelLive', 'isLive']);
    }

    // Null-safe moderators check
    function isModerator(roomData) {
      return roomData.keys().hasAll(['moderators']) &&
             roomData.moderators is list &&
             request.auth.uid in roomData.moderators;
    }

    // ========================================
    // USERS COLLECTION
    // ========================================

    match /users/{userId} {
      // Anyone authenticated can read profiles
      allow read: if isSignedIn();

      // Users can create their own profile
      allow create: if isOwner(userId);

      // Users can update their own profile (for FCM tokens, display name, etc)
      allow update: if isOwner(userId);

      // Users can delete their own profile
      allow delete: if isOwner(userId);

      // FCM TOKENS SUBCOLLECTION
      match /fcmTokens/{tokenId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // FOLLOWERS SUBCOLLECTION
      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow create: if isOwner(followerId);
        allow delete: if isOwner(followerId);
      }

      // FOLLOWING SUBCOLLECTION
      match /following/{followingId} {
        allow read: if isSignedIn();
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // BLOCKED SUBCOLLECTION
      match /blocked/{blockedUserId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && blockedUserId != userId;
        allow delete: if isOwner(userId);
      }

      // EVENT RSVPS SUBCOLLECTION
      match /event_rsvps/{eventId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // ════════════════════════════════════════
      // FRIEND REQUESTS SUBCOLLECTION (inbox/outbox)
      // ════════════════════════════════════════
      match /friendRequests/{requestId} {
        // Owner can read their own inbox/outbox
        allow read: if isOwner(userId);
        // Sender can create a request addressed to this user
        allow create: if isSignedIn() &&
                         (request.auth.uid == request.resource.data.senderId ||
                          request.auth.uid == request.resource.data.receiverId);
        // Sender can cancel; receiver can accept/decline
        allow update: if isSignedIn() &&
                         (request.auth.uid == resource.data.senderId ||
                          request.auth.uid == resource.data.receiverId);
        allow delete: if isSignedIn() &&
                         (request.auth.uid == resource.data.senderId ||
                          request.auth.uid == resource.data.receiverId);
      }

      // ════════════════════════════════════════
      // FRIENDS SUBCOLLECTION
      // ════════════════════════════════════════
      match /friends/{friendUid} {
        // Owner can read their own friends list; other authenticated
        // users can read to check mutual-friend status
        allow read: if isSignedIn();
        // Only the system (batch writes from friend accept) may write.
        // We allow owner writes here — the service enforces bidirectional
        // consistency in a batch; direct client writes are also acceptable
        // because the security model uses the accepter's identity.
        allow write: if isSignedIn() &&
                        (isOwner(userId) || request.auth.uid == friendUid);
      }

      // ════════════════════════════════════════
      // NOTIFICATIONS SUBCOLLECTION
      // ════════════════════════════════════════
      match /notifications/{notificationId} {
        // Only the owner can read their notifications
        allow read: if isOwner(userId);
        // Any authenticated user can create a notification for another user
        // (e.g. sending a friend request creates a notification)
        allow create: if isSignedIn() &&
                         request.resource.data.receiverId == userId;
        // Only the owner can update (mark as read) or delete their own notifications
        allow update, delete: if isOwner(userId);
      }

      // ════════════════════════════════════════
      // MATCH INBOX SUBCOLLECTION
      // /users/{userId}/matches/{matchId}
      // ════════════════════════════════════════
      match /matches/{matchId} {
        // Only the owner can read their own match inbox
        allow read: if isOwner(userId);

        // Any signed-in user can create a match entry for another user
        // (MatchInboxService writes to both users in a batch)
        allow create: if isSignedIn() &&
                         request.resource.data.matchedUserId is string &&
                         request.resource.data.matchedUserId.size() > 0;

        // Only the owner can update (mark as seen) or delete (remove match)
        // their own match inbox entries
        allow update: if isOwner(userId) &&
                         request.resource.data.keys().hasOnly([
                           'matchedUserId', 'timestamp', 'lastInteraction',
                           'isNew', 'source', 'metadata'
                         ]);
        allow delete: if isOwner(userId);
      }
    }

    // ========================================
    // FRIEND REQUESTS (top-level, for cross-user queries)
    // ========================================
    match /friendRequests/{requestId} {
      // Sender or receiver can read
      allow read: if isSignedIn() &&
                     (request.auth.uid == resource.data.senderId ||
                      request.auth.uid == resource.data.receiverId);
      // Sender creates
      allow create: if isSignedIn() &&
                       request.auth.uid == request.resource.data.senderId &&
                       request.resource.data.senderId != request.resource.data.receiverId;
      // Either party can update status (accept / decline / cancel)
      allow update: if isSignedIn() &&
                       (request.auth.uid == resource.data.senderId ||
                        request.auth.uid == resource.data.receiverId);
      // Either party can delete (cancel)
      allow delete: if isSignedIn() &&
                       (request.auth.uid == resource.data.senderId ||
                        request.auth.uid == resource.data.receiverId);
    }

    // ========================================
    // EVENTS COLLECTION
    // ========================================

    match /events/{eventId} {
      // Anyone authenticated can read events
      allow read: if isSignedIn();

      // Verified users can create events
      allow create: if isSignedIn() &&
                       hasValidString('title') &&
                       hasValidString('description') &&
                       request.resource.data.title.size() >= 3 &&
                       request.resource.data.title.size() <= 100 &&
                       request.resource.data.description.size() <= 2000;

      // Only host can update/delete event
      allow update, delete: if isOwner(resource.data.hostId);

      // EVENT ATTENDEES SUBCOLLECTION
      match /attendees/{attendeeId} {
        allow read: if isSignedIn();
        allow create: if isOwner(attendeeId);
        allow update, delete: if isOwner(attendeeId);
      }
    }

    // ========================================
    // ROOMS COLLECTION
    // ========================================

    match /rooms/{roomId} {
      // ✅ CRITICAL FIX: All authenticated users can read rooms (for discovery/joining)
      allow read: if isSignedIn();

      // ✅ Authenticated users can create rooms
      allow create: if isSignedIn() &&
                       hasValidString('title') &&
                       request.resource.data.title.size() >= 3 &&
                       request.resource.data.title.size() <= 100;

      // ✅ Only room creator/host/moderators can update or delete room
      // Exception: any authenticated user may update join-safe fields
      // (participantCount, videoChannelLive, updatedAt, isLive) so that
      // audience members can register their presence.
      allow update: if isSignedIn() && (
                       isRoomJoinUpdate() ||
                       request.auth.uid == resource.data.hostId ||
                       isModerator(resource.data));
      allow delete: if isSignedIn() &&
                       (request.auth.uid == resource.data.hostId ||
                        isModerator(resource.data));

      // ✅ ROOM PARTICIPANTS SUBCOLLECTION - Critical for room joins
      match /participants/{participantId} {
        // All authenticated users can read participant list
        allow read: if isSignedIn();
        // Users can write their own participant data (join/leave/status)
        allow write: if isSignedIn() && request.auth.uid == participantId;
      }

      // ROOM EVENTS SUBCOLLECTION (join/leave logs)
      match /events/{eventId} {
        allow read, create: if isSignedIn();
      }

      // ROOM MESSAGES SUBCOLLECTION - Chat in rooms
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
                         request.resource.data.senderId == request.auth.uid &&
                         // Support both 'content' (new model) and 'text' (legacy)
                         (('content' in request.resource.data &&
                           request.resource.data.content.size() <= 5000) ||
                          ('text' in request.resource.data &&
                           request.resource.data.text.size() <= 5000));
        allow update, delete: if isSignedIn() &&
                                 resource.data.senderId == request.auth.uid;
      }

      // BROADCASTER QUEUE SUBCOLLECTION
      match /broadcasterQueue/{userId} {
        allow read: if isSignedIn();
        // Users manage their own queue entry; host can update any entry
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) ||
                         request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId ||
                         isAdmin();
        allow delete: if isOwner(userId) ||
                         request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId ||
                         isAdmin();
      }

      // CAMERA SUBCOLLECTION (live video slots)
      match /camera/{userId} {
        allow read: if isSignedIn();
        allow create, delete: if isOwner(userId) ||
                                  request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId ||
                                  isAdmin();
        allow update: if isOwner(userId) ||
                         request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId ||
                         isAdmin();
      }

      // REACTIONS SUBCOLLECTION
      match /reactions/{reactionId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
                         request.resource.data.userId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }
    }

    // ========================================
    // FLAT ROOM MESSAGES (legacy support)
    // ========================================

    match /room_messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.senderId);
    }

    // ========================================
    // CHAT ROOMS COLLECTION
    // ========================================

    match /chatRooms/{roomId} {
      // Only participants can read chat
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;

      // Users can create chats if not blocked
      allow create: if isSignedIn() &&
                       'participants' in request.resource.data &&
                       request.auth.uid in request.resource.data.participants;

      // Participants can update chat
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;

      // CHAT MESSAGES SUBCOLLECTION
      match /messages/{messageId} {
        allow read: if isSignedIn() &&
                       request.auth.uid in get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participants;
        allow create: if isSignedIn() &&
                         request.resource.data.senderId == request.auth.uid &&
                         request.resource.data.text.size() <= 5000;
        allow delete: if isOwner(resource.data.senderId);
      }
    }

    // ========================================
    // DIRECT MESSAGES COLLECTION
    // ========================================

    match /direct_messages/{messageId} {
      allow read: if isSignedIn() &&
        (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if isSignedIn() &&
                       request.auth.uid == resource.data.senderId &&
                       request.resource.data.text.size() <= 5000;
      allow update: if isSignedIn() &&
        (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow delete: if isOwner(resource.data.senderId);
    }

    // ========================================
    // NOTIFICATIONS COLLECTION
    // ========================================

    match /notifications/{notificationId} {
      // read + update/delete: resource exists, safe to check resource.data
      allow read: if isSignedIn() &&
                     (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isSignedIn() &&
                       request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSignedIn() &&
                               (request.auth.uid == resource.data.userId || isAdmin());
    }

    // ========================================
    // NOTIFICATION QUEUE (server-write only)
    // ========================================

    match /notificationQueue/{docId} {
      allow read, write: if false; // Cloud Functions only
    }

    // ========================================
    // TIPS COLLECTION
    // ========================================

    match /tips/{tipId} {
      allow read: if isSignedIn() &&
        (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId);
      allow create: if isOwner(resource.data.senderId);
    }

    // ========================================
    // SPEED DATING SESSIONS
    // ========================================

    match /speedDatingSessions/{sessionId} {
      allow read: if isSignedIn() &&
        (request.auth.uid == resource.data.userId1 || request.auth.uid == resource.data.userId2);
      allow create: if isOwner(resource.data.userId1);
      allow update: if isSignedIn() &&
        (request.auth.uid == resource.data.userId1 || request.auth.uid == resource.data.userId2);
    }

    // ========================================
    // SPEED DATING MATCHES
    // ========================================

    match /speedDatingMatches/{matchId} {
      allow read: if isSignedIn() &&
        (request.auth.uid == resource.data.userId1 || request.auth.uid == resource.data.userId2);
      // Require that the creating user is one of the two participants
      allow create: if isSignedIn() &&
        (request.resource.data.userId1 == request.auth.uid ||
         request.resource.data.userId2 == request.auth.uid);
      allow update: if isSignedIn() &&
        (request.auth.uid == resource.data.userId1 || request.auth.uid == resource.data.userId2);
    }

    // ========================================
    // REPORTS COLLECTION
    // ========================================

    match /reports/{reportId} {
      allow read: if false; // Server-side only
      allow create: if isSignedIn() &&
                       hasValidString('reporterId') &&
                       hasValidString('reportedId') &&
                       hasValidString('reason') &&
                       request.resource.data.reporterId == request.auth.uid &&
                       request.resource.data.reporterId != request.resource.data.reportedId &&
                       request.resource.data.reason.size() <= 1000;
      allow update, delete: if false;
    }

    // ========================================
    // CONFIG COLLECTION (read-only)
    // ========================================

    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ========================================
    // TAGS COLLECTION
    // ========================================

    match /tags/{tagId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false; // Server-side only
    }

    // ========================================
    // PRESENCE & HEARTBEAT (Real-time status)
    // ========================================

    match /presence/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /heartbeat/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // ========================================
    // CHATS COLLECTION (private 1-on-1 / match chats)
    // ========================================

    match /chats/{chatId} {
      allow read: if isSignedIn() &&
                     request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() &&
                       'participants' in request.resource.data &&
                       request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() &&
                       request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() &&
                       request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() &&
                         request.resource.data.senderId == request.auth.uid &&
                         request.resource.data.text.size() <= 5000 &&
                         request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }
    }

    // ========================================
    // PUBLIC PROFILES (future split architecture)
    // ========================================

    match /profiles_public/{userId} {
      // Anyone authenticated can read
      allow read: if isSignedIn();
      // Only the owner can write their own public profile
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ========================================
    // PRIVATE PROFILES (locked to owner + admin)
    // ========================================

    match /profiles_private/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ========================================
    // BADGES COLLECTION
    // ========================================

    match /badges/{badgeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); // Server/admin only
    }

    match /user_badges/{docId} {
      allow read: if isSignedIn() &&
                     (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() &&
                       request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ========================================
    // FRIENDS COLLECTION
    // ========================================

    match /friends/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // ========================================
    // SHARED FILES
    // ========================================

    match /shared_files/{fileId} {
      allow read: if isSignedIn() &&
                     (resource.data.uploaderId == request.auth.uid ||
                      resource.data.sharedWithRoomId != null);
      allow create: if isSignedIn() &&
                       request.resource.data.uploaderId == request.auth.uid;
      allow update, delete: if isSignedIn() &&
                               resource.data.uploaderId == request.auth.uid;
    }

    // ========================================
    // CAMERA PERMISSIONS
    // ========================================

    match /camera_permissions/{permissionId} {
      allow read: if isSignedIn() &&
                     (resource.data.userId == request.auth.uid ||
                      resource.data.requestedBy == request.auth.uid ||
                      isAdmin());
      allow create: if isSignedIn() &&
                       request.resource.data.requestedBy == request.auth.uid;
      allow update: if isSignedIn() &&
                       (resource.data.userId == request.auth.uid ||
                        isRoomHost(resource.data.roomId) ||
                        isAdmin());
      allow delete: if isSignedIn() &&
                       (resource.data.userId == request.auth.uid ||
                        isRoomHost(resource.data.roomId) ||
                        isAdmin());
    }

    // ========================================
    // COIN ECONOMY — DAILY LOGINS & MESSAGE COUNTS
    // ========================================

    match /user_daily_logins/{docId} {
      // Doc ID format: {userId}_{date} — owner can read/write their own
      allow read, write: if isSignedIn() &&
                            docId.matches(request.auth.uid + '_.*');
    }

    match /user_message_counts/{docId} {
      allow read, write: if isSignedIn() &&
                            docId.matches(request.auth.uid + '_.*');
    }

    // ========================================
    // MODERATION LOGS (server-side only)
    // ========================================

    match /moderation_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions only
    }

    // ========================================
    // CRASH REPORTS & PERFORMANCE (write-only, server reads)
    // ========================================

    match /crash_reports/{docId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /performance_issues/{docId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    // ========================================
    // SYSTEM COLLECTION (read-only for app)
    // ========================================

    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /health_check/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ========================================
    // FLAT MESSAGES COLLECTION (legacy/moderation)
    // ========================================

    match /messages/{messageId} {
      allow read: if isSignedIn() &&
                     (resource.data.senderId == request.auth.uid ||
                      resource.data.receiverId == request.auth.uid ||
                      isAdmin());
      allow create: if isSignedIn() &&
                       request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }

    // ========================================
    // WITHDRAWALS COLLECTION
    // ========================================

    match /withdrawals/{withdrawalId} {
      // Users can read only their own withdrawal requests
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Users can submit a withdrawal for themselves only
      allow create: if isSignedIn() &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.amount is number &&
                       request.resource.data.amount > 0;
      // Only admin/server can update (process, reject)
      allow update, delete: if isAdmin();
    }

    // ========================================
    // MATCHES COLLECTION
    // ========================================

    match /matches/{matchId} {
      allow read: if isSignedIn() &&
                     (resource.data.userId1 == request.auth.uid ||
                      resource.data.userId2 == request.auth.uid);
      // Require that the creating user is one of the two participants
      allow create: if isSignedIn() &&
                       (request.resource.data.userId1 == request.auth.uid ||
                        request.resource.data.userId2 == request.auth.uid);
      allow update: if isSignedIn() &&
                       (resource.data.userId1 == request.auth.uid ||
                        resource.data.userId2 == request.auth.uid);
      allow delete: if false;
    }

    // ========================================
    // ADMIN COLLECTION (server-side only)
    // ========================================

    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    // ========================================
    // ADS MONETIZATION SYSTEM
    // ========================================

    // Advertisers — only admins can create/modify billing fields.
    // Any authenticated user can read active advertisers (for ad serving).
    match /advertisers/{advertiserId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();

      // Admins can update anything.
      // Non-admins cannot touch billing-sensitive fields.
      allow update: if isAdmin() ||
                       (isSignedIn() &&
                        !request.resource.data.diff(resource.data)
                          .affectedKeys()
                          .hasAny(['impressionsRemaining', 'clicksRemaining',
                                   'billingStatus', 'promoCode']));

      allow delete: if isAdmin();
    }

    // Ads (creatives) — admins manage; authenticated users can read active ads.
    match /ads/{adId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();

      // Allow impression/click counter increments by authenticated users.
      // Only impressionCount and clickCount may be incremented by non-admins.
      allow update: if isSignedIn() &&
                       request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['impressionCount', 'clickCount', 'updatedAt']);
    }

    // Promo codes — admins manage; authenticated users can read to validate.
    // Only admins can mark a promo as active/inactive.
    // A user can redeem (set redeemedAt) if the code is active and not yet redeemed.
    match /promoCodes/{code} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();

      // Admin: full update
      allow update: if isAdmin();

      // Any signed-in user may set redeemedAt once (redemption).
      allow update: if isSignedIn() &&
                       resource.data.active == true &&
                       resource.data.redeemedAt == null &&
                       request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly(['redeemedAt']);
    }

    // ========================================
    // DEFAULT: DENY ALL
    // ========================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
